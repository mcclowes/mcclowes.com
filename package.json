{
  "name": "mcclowes.com",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "prestart": "node scripts/generate-env.js",
    "start": "docusaurus start",
    "prebuild": "node scripts/generate-env.js",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "test": "node --require ./scripts/test-register.cjs --test",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.14"
  },
  "husky": {
    "hooks": {
      "pre-push": "command -v git-lfs >/dev/null 2>&1 && git lfs pre-push \"$@\" || true"
    }
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/plugin-ideal-image": "3.10.1",
    "@docusaurus/plugin-vercel-analytics": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@docusaurus/theme-live-codeblock": "3.10.1",
    "@docusaurus/theme-mermaid": "3.10.1",
    "@giscus/react": "^3.1.0",
    "@mdx-js/react": "^3.0.1",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-cookie-consent": "^4.6.0",
    "docusaurus-plugin-glossary": "^3.3.3",
    "docusaurus-plugin-image-zoom": "^3.0.1",
    "docusaurus-plugin-sass": "^0.2.6",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.5",
    "posthog-js": "^1.378.1",
    "prism-react-renderer": "^2.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-masonry-css": "^1.0.16",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-modules-commonjs": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "sass": "^1.100.0"
  }
}
